{
    "name": "template/landing-cookie-consent",
    "description": "Cookie consent and LGPD privacy module for Laravel landing pages.",
    "type": "library",
    "license": "MIT",
    "version": "1.0.0",
    "autoload": {
        "psr-4": {
            "Template\\LandingCookieConsent\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Template\\LandingCookieConsent\\LandingCookieConsentServiceProvider"
            ]
        }
    },
    "require": {
        "php": "^8.3",
        "illuminate/database": "^13.0",
        "illuminate/http": "^13.0",
        "illuminate/support": "^13.0",
        "illuminate/view": "^13.0"
    }
}
