{
    "name": "template/landing-core",
    "description": "Landing page core module with shared theme, registries, rendering helpers, and base Blade components.",
    "type": "library",
    "license": "MIT",
    "version": "1.0.0",
    "autoload": {
        "psr-4": {
            "Template\\LandingCore\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "Template\\LandingCore\\LandingCoreServiceProvider"
            ]
        }
    },
    "require": {
        "php": "^8.3",
        "illuminate/http": "^13.0",
        "illuminate/routing": "^13.0",
        "illuminate/support": "^13.0",
        "illuminate/view": "^13.0"
    }
}
